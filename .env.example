# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit real secrets.

# --- Business Central OData endpoint (required) ---
# Full URL to the contact entity set. Example:
#   https://api.businesscentral.dynamics.com/v2.0/{tenant}/{env}/ODataV4/Company('YourCompany')/Contact
BC_CONTACTS_URL=

# --- Auth: pick ONE of the two blocks below ---

# Option A: OAuth2 client credentials (BC Online / SaaS, recommended)
BC_TENANT_ID=
BC_CLIENT_ID=
BC_CLIENT_SECRET=
# Leave default unless you have a custom scope
BC_OAUTH_SCOPE=https://api.businesscentral.dynamics.com/.default

# Option B: Basic Auth with Web Service Access Key (BC On-Premises)
# BC_USERNAME=
# BC_ACCESS_KEY=

# --- Webhook security (recommended) ---
# Fonio must send `Authorization: Bearer <this value>` on every request.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# --- Phone matching ---
# Phone fields on the Contact entity to search (comma-separated).
BC_PHONE_FIELDS=phoneNo,mobilePhoneNo,phoneNo2,mobilePhoneNo2,privatPhoneNo,privatMobilePhoneNo
# Default country code used to generate phone format variants (49 = Germany).
BC_DEFAULT_COUNTRY_CODE=49

# --- Zammad (helpdesk: one ticket per call, post-processing path) ---
# Base URL of the instance, no trailing /api. e.g. https://your.zammad.com
ZAMMAD_URL=
# API token: Zammad Profile -> Token Access (needs ticket.agent perms).
# Sent as `Authorization: Token token=<...>`.
ZAMMAD_TOKEN=
# Group new tickets are filed under (must already exist in Zammad), e.g. LUMINA.
ZAMMAD_GROUP=Users
